:root {
  --ink: #2f241f;
  --muted: #6f625a;
  --paper: #fffaf1;
  --paper-2: #f6efe1;
  --red: #8b1e1e;
  --red-dark: #641313;
  --gold: #c49a3a;
  --green: #2f6b57;
  --line: rgba(90, 61, 34, .18);
  --shadow: 0 18px 48px rgba(53, 30, 16, .16);
  --radius: 8px;
  font-family: "Noto Serif TC", "Noto Sans TC", "Microsoft JhengHei", system-ui, sans-serif;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  color: var(--ink);
  background: linear-gradient(180deg, #fffaf1 0%, #f8f2e8 42%, #fffaf1 100%);
  line-height: 1.75;
}

img {
  display: block;
  max-width: 100%;
}

a {
  color: inherit;
  text-decoration: none;
}

.site-header {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  min-height: 76px;
  padding: 12px clamp(18px, 4vw, 56px);
  background: rgba(255, 250, 241, .92);
  border-bottom: 1px solid var(--line);
  backdrop-filter: blur(16px);
  box-shadow: 0 10px 34px rgba(53, 30, 16, .08);
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  font-size: 15px;
  line-height: 1.2;
  font-weight: 700;
  min-width: 0;
}

.brand img {
  width: 46px;
  height: 46px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid var(--gold);
}

.brand b {
  color: var(--red);
  font-size: 18px;
}

.site-nav {
  display: flex;
  align-items: center;
  gap: 8px;
}

.site-nav a {
  padding: 8px 12px;
  border-radius: 999px;
  color: var(--muted);
  font-size: 15px;
  font-weight: 700;
}

.site-nav a:hover,
.site-nav a:focus-visible {
  color: var(--red);
  background: rgba(139, 30, 30, .08);
  outline: 0;
}

.menu-toggle {
  display: none;
  width: 44px;
  height: 44px;
  border: 1px solid var(--line);
  border-radius: 50%;
  background: #fff;
  padding: 11px;
}

.menu-toggle span {
  display: block;
  height: 2px;
  margin: 5px 0;
  background: var(--red);
}

.hero {
  position: relative;
  min-height: 92svh;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  padding: 120px clamp(20px, 6vw, 76px) 92px;
  background: #211710;
}

.hero-image,
.hero-shade {
  position: absolute;
  inset: 0;
}

.hero-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-shade {
  background:
    linear-gradient(90deg, rgba(24, 12, 8, .88), rgba(24, 12, 8, .54) 44%, rgba(24, 12, 8, .12)),
    linear-gradient(0deg, rgba(24, 12, 8, .72), rgba(24, 12, 8, .05) 46%);
}

.hero-content {
  position: relative;
  width: min(760px, 100%);
  color: #fff;
}

.kicker,
.section-heading p,
.contact-copy p {
  margin: 0 0 10px;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: .08em;
  font-size: 13px;
  font-weight: 800;
}

.hero h1 {
  margin: 0;
  font-size: clamp(36px, 7vw, 80px);
  line-height: 1.08;
  letter-spacing: 0;
  text-wrap: balance;
}

.hero-copy {
  max-width: 620px;
  margin: 22px 0 0;
  font-size: clamp(17px, 2.2vw, 22px);
  color: rgba(255, 255, 255, .9);
}

.hero-actions,
.contact-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 30px;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 46px;
  padding: 10px 18px;
  border-radius: var(--radius);
  border: 1px solid rgba(255, 255, 255, .46);
  font-weight: 800;
}

.btn.primary {
  background: var(--red);
  border-color: var(--red);
  color: #fff;
}

.btn.ghost {
  color: #fff;
  background: rgba(255, 255, 255, .12);
}

.btn.dark {
  color: var(--red);
  background: #fff;
  border-color: rgba(139, 30, 30, .22);
}

.quick-info {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--line);
  border-bottom: 1px solid var(--line);
}

.quick-info div {
  min-width: 0;
  padding: 24px clamp(18px, 3vw, 36px);
  background: #fff7e9;
}

.quick-info strong,
.quick-info span,
.quick-info a {
  display: block;
}

.quick-info strong {
  color: var(--red);
  font-size: 14px;
}

.quick-info span,
.quick-info a {
  color: var(--ink);
  font-size: 18px;
  font-weight: 700;
  overflow-wrap: anywhere;
}

.ceremony-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  padding: 0 clamp(20px, 6vw, 76px);
  background: #2a1a12;
  border-top: 1px solid rgba(255, 255, 255, .08);
  border-bottom: 1px solid var(--line);
}

.ceremony-strip div {
  min-width: 0;
  padding: 22px clamp(16px, 2vw, 28px);
  background: linear-gradient(180deg, #342116, #24160f);
  color: #fff;
}

.ceremony-strip span,
.ceremony-strip strong {
  display: block;
}

.ceremony-strip span {
  margin-bottom: 4px;
  color: var(--gold);
  font-size: 13px;
  font-weight: 800;
}

.ceremony-strip strong {
  font-size: clamp(17px, 1.8vw, 22px);
  line-height: 1.35;
}

.section {
  padding: clamp(64px, 9vw, 110px) clamp(20px, 6vw, 76px);
}

.section-heading {
  margin-bottom: 28px;
}

.section-heading h2,
.contact-copy h2 {
  margin: 0;
  font-size: clamp(30px, 4vw, 48px);
  line-height: 1.16;
}

.story-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(280px, .95fr);
  gap: clamp(28px, 5vw, 64px);
  align-items: start;
}

.story-copy {
  font-size: clamp(18px, 2vw, 22px);
}

.story-copy p {
  margin: 0 0 18px;
}

.timeline {
  margin: 0;
  padding: 0;
  list-style: none;
  border-left: 2px solid var(--gold);
}

.timeline li {
  position: relative;
  padding: 0 0 28px 26px;
}

.timeline li::before {
  content: "";
  position: absolute;
  top: 8px;
  left: -7px;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--red);
  box-shadow: 0 0 0 5px var(--paper);
}

.timeline time {
  display: block;
  color: var(--red);
  font-weight: 900;
}

.timeline span {
  color: var(--muted);
}

.visit-band {
  background: var(--red-dark);
  color: #fff;
}

.visit-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}

.visit-grid article {
  padding: 26px;
  border: 1px solid rgba(255, 255, 255, .18);
  border-radius: var(--radius);
  background: rgba(255, 255, 255, .06);
}

.icon {
  display: inline-grid;
  place-items: center;
  width: 42px;
  height: 42px;
  margin-bottom: 14px;
  border-radius: 50%;
  background: var(--gold);
  color: #2d1709;
  font-weight: 900;
}

.visit-grid h3,
.news-layout h3 {
  margin: 0 0 8px;
  font-size: 24px;
}

.visit-grid p,
.news-layout p {
  margin: 0;
  color: rgba(255, 255, 255, .84);
}

.news {
  background: #fff;
}

.news-layout {
  display: grid;
  grid-template-columns: minmax(280px, 460px) minmax(0, 1fr);
  gap: clamp(24px, 5vw, 56px);
  align-items: center;
}

.news-layout img {
  width: 100%;
  aspect-ratio: 4 / 5;
  object-fit: cover;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

.news-layout p {
  color: var(--muted);
  font-size: 18px;
}

.news-layout .date {
  color: var(--green);
  font-weight: 900;
  margin-bottom: 10px;
}

.news-layout h3 {
  color: var(--ink);
  font-size: clamp(28px, 4vw, 46px);
}

.text-link {
  display: inline-block;
  margin-top: 22px;
  color: var(--red);
  font-weight: 900;
  border-bottom: 2px solid var(--gold);
}

.facebook-live {
  background: #f8f2e8;
}

.facebook-sync {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(320px, 540px);
  gap: clamp(24px, 5vw, 56px);
  align-items: start;
}

.facebook-sync-copy {
  max-width: 560px;
  font-size: 19px;
}

.facebook-sync-copy p {
  margin: 0;
  color: var(--muted);
}

.facebook-frame {
  width: 100%;
  min-height: 520px;
  padding: 18px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #fff;
  box-shadow: var(--shadow);
  overflow: hidden;
}

.facebook-frame iframe {
  width: 100%;
  max-width: 500px;
  min-height: 640px;
  margin: 0 auto;
  display: block;
}

.photos {
  background: var(--paper-2);
}

.gallery-heading {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 20px;
}

.gallery-heading span {
  display: block;
  max-width: 440px;
  color: var(--muted);
  font-weight: 700;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(148px, 160px));
  justify-content: center;
  gap: 18px;
  max-width: 1060px;
  margin: 0 auto;
}

.photo-grid button {
  width: 160px;
  min-height: 210px;
  padding: 10px 10px 12px;
  border: 1px solid rgba(90, 61, 34, .16);
  border-radius: var(--radius);
  background: #fffaf1;
  box-shadow: 0 12px 30px rgba(53, 30, 16, .12);
  cursor: zoom-in;
}

.photo-grid img {
  width: 140px;
  height: 140px;
  margin: 0 auto;
  aspect-ratio: 1;
  object-fit: cover;
  border-radius: 6px;
  transition: transform .28s ease, filter .28s ease;
}

.photo-grid span {
  display: block;
  margin-top: 10px;
  color: var(--muted);
  font-size: 13px;
  font-weight: 800;
}

.photo-grid button:hover img,
.photo-grid button:focus-visible img {
  transform: scale(1.035);
  filter: contrast(1.04) saturate(1.04);
}

.contact-section {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 24px;
  padding: clamp(48px, 8vw, 82px) clamp(20px, 6vw, 76px);
  color: #fff;
  background: linear-gradient(135deg, #331f16, var(--red-dark));
}

address {
  display: grid;
  gap: 4px;
  margin-top: 16px;
  font-style: normal;
  font-size: 20px;
}

.site-footer {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  padding: 24px clamp(20px, 6vw, 76px);
  background: #201710;
  color: rgba(255, 255, 255, .72);
  font-size: 14px;
}

.site-footer p {
  margin: 0;
}

.lightbox {
  width: min(92vw, 520px);
  padding: 0;
  border: 0;
  border-radius: var(--radius);
  background: transparent;
}

.lightbox::backdrop {
  background: rgba(20, 10, 6, .86);
}

.lightbox img {
  width: min(80vw, 340px);
  margin: 0 auto;
  padding: 12px;
  max-height: 86svh;
  object-fit: contain;
  border-radius: var(--radius);
  background: #fffaf1;
  filter: contrast(1.03) saturate(1.04);
}

.lightbox-close {
  position: fixed;
  top: 18px;
  right: 18px;
  width: 46px;
  height: 46px;
  border-radius: 50%;
  border: 0;
  background: #fff;
  color: var(--red);
  font-size: 30px;
  line-height: 1;
  cursor: pointer;
}

@media (max-width: 900px) {
  .site-header {
    min-height: 68px;
  }

  .menu-toggle {
    display: inline-block;
  }

  .site-nav {
    position: absolute;
    top: calc(100% + 1px);
    right: 16px;
    left: 16px;
    display: none;
    flex-direction: column;
    align-items: stretch;
    padding: 10px;
    background: #fffaf1;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .site-header.nav-open .site-nav {
    display: flex;
  }

  .site-nav a {
    border-radius: var(--radius);
  }

  .hero {
    min-height: 86svh;
    padding-top: 104px;
  }

  .quick-info,
  .ceremony-strip,
  .story-grid,
  .news-layout,
  .facebook-sync,
  .contact-section {
    grid-template-columns: 1fr;
  }

  .ceremony-strip {
    padding: 0;
  }

  .gallery-heading {
    display: block;
  }

  .gallery-heading span {
    margin-top: 10px;
  }

  .visit-grid {
    grid-template-columns: 1fr;
  }

  .contact-actions {
    margin-top: 0;
  }
}

@media (max-width: 640px) {
  .brand span {
    font-size: 13px;
  }

  .brand b {
    font-size: 16px;
  }

  .hero {
    padding: 104px 18px 58px;
  }

  .hero-shade {
    background:
      linear-gradient(0deg, rgba(24, 12, 8, .88), rgba(24, 12, 8, .24)),
      linear-gradient(90deg, rgba(24, 12, 8, .62), rgba(24, 12, 8, .16));
  }

  .hero-actions,
  .contact-actions {
    flex-direction: column;
  }

  .btn {
    width: 100%;
  }

  .quick-info {
    grid-template-columns: 1fr 1fr;
  }

  .quick-info div {
    padding: 18px;
  }

  .quick-info span,
  .quick-info a {
    font-size: 16px;
  }

  .section {
    padding: 56px 18px;
  }

  .facebook-frame {
    min-height: 500px;
    padding: 10px;
  }

  .facebook-frame iframe {
    min-height: 560px;
  }

  .photo-grid {
    grid-template-columns: repeat(2, 148px);
    gap: 12px;
  }

  .photo-grid button {
    width: 148px;
    min-height: 196px;
  }

  .photo-grid img {
    width: 128px;
    height: 128px;
  }

  .site-footer {
    display: block;
  }

  .site-footer p + p {
    margin-top: 8px;
  }
}

@media (display-mode: standalone) {
  .site-header {
    padding-top: max(12px, env(safe-area-inset-top));
  }
}
